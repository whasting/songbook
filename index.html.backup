<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>90s Country Songbook</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Georgia', 'Times New Roman', serif;
            background: linear-gradient(135deg, #8B4513 0%, #D2691E 100%);
            color: #2c2c2c;
            line-height: 1.6;
        }

        .password-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #8B4513 0%, #D2691E 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .password-overlay.hidden {
            display: none;
        }

        .password-box {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            text-align: center;
            max-width: 400px;
        }

        .password-box h1 {
            color: #8B4513;
            margin-bottom: 10px;
            font-size: 2em;
        }

        .password-box p {
            color: #666;
            margin-bottom: 20px;
        }

        .password-box input {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            border: 2px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
        }

        .password-box button {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #8B4513 0%, #D2691E 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .password-box button:hover {
            transform: scale(1.05);
        }

        .error {
            color: #d32f2f;
            margin-top: 10px;
            font-size: 14px;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px;
        }

        header {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            text-align: center;
            margin-bottom: 30px;
        }

        header h1 {
            color: #8B4513;
            font-size: 2.5em;
            margin-bottom: 10px;
        }

        header p {
            color: #666;
            font-style: italic;
        }

        .section {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            margin-bottom: 30px;
        }

        .section h2 {
            color: #8B4513;
            border-bottom: 3px solid #D2691E;
            padding-bottom: 10px;
            margin-bottom: 20px;
            font-size: 1.8em;
        }

        .song {
            background: #fafafa;
            padding: 20px;
            margin-bottom: 20px;
            border-radius: 10px;
            border-left: 5px solid #D2691E;
        }

        .song-header {
            margin-bottom: 15px;
        }

        .song-title {
            font-size: 1.4em;
            color: #8B4513;
            font-weight: bold;
        }

        .song-artist {
            color: #666;
            font-style: italic;
            margin-left: 10px;
        }

        .song-content {
            background: white;
            padding: 15px;
            border-radius: 8px;
            white-space: pre-wrap;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            line-height: 1.8;
            min-height: 100px;
            color: #444;
        }

        .song-content.placeholder {
            color: #999;
            font-style: italic;
            font-family: 'Georgia', serif;
        }

        footer {
            text-align: center;
            color: white;
            padding: 20px;
            margin-top: 30px;
        }

        @media (max-width: 768px) {
            .container {
                padding: 10px;
            }

            header h1 {
                font-size: 1.8em;
            }

            .section {
                padding: 20px;
            }

            .song {
                padding: 15px;
            }

            .song-content {
                font-size: 12px;
            }
        }
    </style>
</head>
<body>
    <!-- Password Protection Overlay -->
    <div class="password-overlay" id="passwordOverlay">
        <div class="password-box">
            <h1>🎸 Country Songbook</h1>
            <p>Enter password to access</p>
            <input type="password" id="passwordInput" placeholder="Enter password">
            <button onclick="checkPassword()">Unlock</button>
            <div class="error" id="errorMessage"></div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container">
        <header>
